# NutriSnap-X Environment Variables
# Copy this file to .env and fill in your values

# Flask secret key — change this to a long random string in production
SECRET_KEY=nutrisnap-x-change-this-in-production

# OpenAI API key — needed for AI chatbot (optional; falls back to rule-based)
OPENAI_API_KEY=your-openai-key-here

# Flask debug mode (set to false in production)
FLASK_DEBUG=true

# Port (used by gunicorn / Render)
PORT=5000
